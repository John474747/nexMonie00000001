
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if authenticated or in demo/dev mode
    function isAuthOrDemo() {
      return request.auth != null || true;
    }

    // User Profiles
    match /users/{userId} {
      allow read, write: if isAuthOrDemo();
    }

    // Merchant Profiles
    match /merchant_profiles/{userId} {
      allow read, write: if isAuthOrDemo();
    }

    // P2P Advertisements
    match /p2p_ads/{adId} {
      allow read, write: if isAuthOrDemo();
    }

    // P2P Orders
    match /p2p_orders/{orderId} {
      allow read, write: if isAuthOrDemo();
      
      // Order Messages
      match /messages/{messageId} {
        allow read, write: if isAuthOrDemo();
      }
    }

    // Wallets
    match /wallets/{walletId} {
      allow read, write: if isAuthOrDemo();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read, write: if isAuthOrDemo();
    }

    // Deposits
    match /deposits/{depositId} {
      allow read, write: if isAuthOrDemo();
    }

    // Transaction Requests
    match /transaction_requests/{requestId} {
      allow read, write: if isAuthOrDemo();
    }

    // App Configuration
    match /app_config/{configId} {
      allow read, write: if isAuthOrDemo();
    }
    
    // Default fallback
    match /{document=**} {
      allow read, write: if isAuthOrDemo();
    }
  }
}
